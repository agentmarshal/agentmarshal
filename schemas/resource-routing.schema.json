{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentmarshal.local/schemas/resource-routing.schema.json",
  "title": "AgentMarshal resource-aware model routing policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "blocked_tier",
    "escalation",
    "vendors",
    "routes"
  ],
  "properties": {
    "schema": {
      "const": 1
    },
    "blocked_tier": {
      "const": "operator/blocked"
    },
    "escalation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chain",
        "triggers"
      ],
      "properties": {
        "chain": {
          "type": "array",
          "prefixItems": [
            {
              "const": "economy"
            },
            {
              "const": "standard"
            },
            {
              "const": "critical"
            },
            {
              "const": "operator/blocked"
            }
          ],
          "items": false,
          "minItems": 4,
          "maxItems": 4
        },
        "triggers": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "failed_acceptance",
              "pipeline_failed",
              "blocking_finding",
              "retry_budget_exhausted",
              "repeated_ambiguity",
              "scope_provenance_violation",
              "insufficient_confidence",
              "quality_gate_failed"
            ]
          }
        }
      }
    },
    "vendors": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "tiers"
        ],
        "properties": {
          "tiers": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "economy",
              "standard",
              "critical"
            ],
            "properties": {
              "economy": {
                "$ref": "#/$defs/tierSpec"
              },
              "standard": {
                "$ref": "#/$defs/tierSpec"
              },
              "critical": {
                "$ref": "#/$defs/tierSpec"
              }
            }
          }
        }
      }
    },
    "routes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "vendor",
          "activity",
          "task_class",
          "difficulty",
          "risk_level",
          "tier"
        ],
        "properties": {
          "vendor": {
            "$ref": "#/$defs/vendorName"
          },
          "activity": {
            "enum": [
              "implementation",
              "review",
              "operations",
              "analysis",
              "documentation",
              "release"
            ]
          },
          "task_class": {
            "enum": [
              "documentation",
              "ci",
              "frontend",
              "backend",
              "review",
              "operations",
              "security",
              "release",
              "analysis"
            ]
          },
          "difficulty": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "risk_level": {
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "tier": {
            "enum": [
              "economy",
              "standard",
              "critical"
            ]
          }
        }
      }
    }
  },
  "$defs": {
    "vendorName": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "tierSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model",
        "reasoning_effort"
      ],
      "properties": {
        "model": {
          "type": "string",
          "minLength": 1
        },
        "reasoning_effort": {
          "enum": [
            "low",
            "medium",
            "high",
            "max"
          ]
        }
      }
    }
  }
}
