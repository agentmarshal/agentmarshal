{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentmarshal.local/schemas/agmake-runbook.schema.json",
  "title": "AgentMarshal AgMake runbook spec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "task",
    "branch",
    "target_branch",
    "base_ref",
    "provider",
    "review",
    "sections"
  ],
  "properties": {
    "schema": {
      "const": 1
    },
    "task": {
      "type": "string",
      "pattern": "^CR-[0-9]{3,}$"
    },
    "branch": {
      "$ref": "#/$defs/refName"
    },
    "target_branch": {
      "$ref": "#/$defs/refName"
    },
    "base_ref": {
      "$ref": "#/$defs/refName"
    },
    "provider": {
      "type": "string",
      "enum": [
        "gitflic",
        "github",
        "gitlab",
        "mock"
      ]
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "vendor",
        "model",
        "max_loops"
      ],
      "properties": {
        "vendor": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{1,62}[a-z0-9]$"
        },
        "model": {
          "type": "string",
          "minLength": 2,
          "maxLength": 128
        },
        "max_loops": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        }
      }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/section"
      }
    }
  },
  "$defs": {
    "refName": {
      "type": "string",
      "pattern": "^(?!/)(?!.*\\.\\.)(?!.*//)[A-Za-z0-9._/@-]+$"
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "mode",
        "rollback",
        "artifacts"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[0-9]{2,3}$"
        },
        "title": {
          "type": "string",
          "minLength": 3,
          "maxLength": 120
        },
        "mode": {
          "type": "string",
          "enum": [
            "sequential"
          ]
        },
        "after": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[0-9]{2,3}$"
          },
          "uniqueItems": true
        },
        "locks": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9._/-]{0,62}$"
          },
          "uniqueItems": true
        },
        "rollback": {
          "type": "string",
          "enum": [
            "none",
            "local-temp",
            "local-draft",
            "manual-handoff"
          ]
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._{}${}/:-]+$"
          },
          "uniqueItems": true
        }
      }
    }
  }
}
