{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentmarshal.local/schemas/agent-run-stat.schema.json",
  "title": "AgentMarshal normalized agent run statistic",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "id", "recorded_at", "task", "role", "vendor", "model",
    "profile", "activity", "outcome", "trial", "commit", "duration_seconds",
    "turns", "human_interventions", "retries", "scope_violations",
    "tests_passed", "tests_failed", "findings_count", "changed_files",
    "additions", "deletions", "input_tokens", "output_tokens", "cost_usd",
    "source_artifact"
  ],
  "properties": {
    "schema": {"const": 1},
    "id": {"type": "string", "pattern": "^RUN-[0-9]{8}T[0-9]{6}Z-[a-z0-9-]+-[0-9a-f]{8}$"},
    "recorded_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
    "task": {"type": "string", "pattern": "^CR-[0-9]+$"},
    "role": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
    "vendor": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
    "model": {"type": "string", "minLength": 1},
    "reasoning_effort": {
      "enum": ["unspecified", "low", "medium", "high", "max"],
      "description": "Optional for historical records. Validators treat absence as 'unspecified'; new launchers should write an explicit effort."
    },
    "profile": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "activity": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
    "outcome": {"enum": ["success", "approved", "changes_required", "blocked", "rejected", "failed", "canceled", "partial", "negative"]},
    "trial": {"type": "boolean"},
    "commit": {"type": "string", "pattern": "^(none|[0-9a-f]{40})$"},
    "duration_seconds": {"type": "integer", "minimum": 0},
    "turns": {"type": "integer", "minimum": 0},
    "human_interventions": {"type": "integer", "minimum": 0},
    "retries": {"type": "integer", "minimum": 0},
    "scope_violations": {"type": "integer", "minimum": 0},
    "tests_passed": {"type": "integer", "minimum": 0},
    "tests_failed": {"type": "integer", "minimum": 0},
    "findings_count": {"type": "integer", "minimum": 0},
    "changed_files": {"type": "integer", "minimum": 0},
    "additions": {"type": "integer", "minimum": 0},
    "deletions": {"type": "integer", "minimum": 0},
    "input_tokens": {"type": "integer", "minimum": 0},
    "output_tokens": {"type": "integer", "minimum": 0},
    "cost_usd": {"type": "number", "minimum": 0},
    "source_artifact": {"type": "string", "minLength": 1}
  }
}
