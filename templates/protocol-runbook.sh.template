#!/usr/bin/env bash
# AgentMarshal task-local protocol runbook template.
# Concrete runbooks belong in ignored host runtime state:
#   .agents/tmp/runner/CR-NNN-runbook.sh
set -euo pipefail

TASK_ID="__TASK_ID__"
BRANCH="__BRANCH__"
BASE_REF="${BASE_REF:-origin/master}"
TARGET_BRANCH="${TARGET_BRANCH:-master}"
REVIEW_VENDOR="${REVIEW_VENDOR:-claude}"
REVIEW_MODEL="${REVIEW_MODEL:-claude-sonnet-4-5}"
MAX_REVIEW_LOOPS="${MAX_REVIEW_LOOPS:-3}"
PIPELINE_TIMEOUT="${PIPELINE_TIMEOUT:-1800}"
PIPELINE_POLL="${PIPELINE_POLL:-15}"
RUNBOOK_FROM="${RUNBOOK_FROM:-00}"

ROOT="$(git rev-parse --show-toplevel)"
RUN_ROOT="$ROOT/.agents/runs/runner/$TASK_ID"
mkdir -p "$RUN_ROOT"
LOG_FILE="$RUN_ROOT/$(date -u +%Y%m%dT%H%M%SZ)-runbook.log"
STATE_FILE="$RUN_ROOT/state.env"

section() {
  printf '\n== %s ==\n' "$*" | tee -a "$LOG_FILE"
}

note() {
  printf '%s\n' "$*" | tee -a "$LOG_FILE"
}

should_run() {
  local step="$1"
  (( 10#$step >= 10#$RUNBOOK_FROM ))
}

load_state() {
  [[ -f "$STATE_FILE" ]] || return 0
  # shellcheck disable=SC1090
  source "$STATE_FILE"
}

write_state() {
  umask 077
  {
    printf 'IMPLEMENTATION_SHA=%q\n' "${IMPLEMENTATION_SHA:-}"
    printf 'MR_ID=%q\n' "${MR_ID:-}"
    printf 'PIPELINE_ID=%q\n' "${PIPELINE_ID:-}"
    printf 'REVIEW_FILE=%q\n' "${REVIEW_FILE:-}"
    printf 'IMPLEMENTATION_REVIEW_FILE=%q\n' "${IMPLEMENTATION_REVIEW_FILE:-}"
    printf 'COMPLETION_BRANCH=%q\n' "${COMPLETION_BRANCH:-}"
    printf 'COMPLETION_SHA=%q\n' "${COMPLETION_SHA:-}"
    printf 'COMPLETION_MR_ID=%q\n' "${COMPLETION_MR_ID:-}"
    printf 'COMPLETION_REVIEW_FILE=%q\n' "${COMPLETION_REVIEW_FILE:-}"
  } > "$STATE_FILE"
}

fail() {
  local section_name="$1" reason="$2"
  {
    printf '\nAGENTMARSHAL_RUNBOOK_FAILURE\n'
    printf 'Task: %s\n' "$TASK_ID"
    printf 'Section: %s\n' "$section_name"
    printf 'Branch: %s\n' "$BRANCH"
    printf 'SHA: %s\n' "${IMPLEMENTATION_SHA:-n/a}"
    printf 'MR: %s\n' "${MR_ID:-n/a}"
    printf 'Pipeline: %s\n' "${PIPELINE_ID:-n/a}"
    printf 'Review-File: %s\n' "${REVIEW_FILE:-n/a}"
    printf 'Log: %s\n' "$LOG_FILE"
    printf 'Reason: %s\n' "$reason"
    printf 'Next-Hint: Re-open a model session with this block and the log path.\n'
  } | tee -a "$LOG_FILE" >&2
  exit 1
}

run() {
  note "+ $*"
  "$@" 2>&1 | tee -a "$LOG_FILE"
}

review_field() {
  local file="$1" key="$2"
  awk -v wanted="$key" '
    {
      line=$0
      gsub(/\*\*/, "", line)
      sub(/^[[:space:]#>*-]+/, "", line)
      pos=index(line, ":")
      if (!pos) next
      name=substr(line, 1, pos-1)
      value=substr(line, pos+1)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", name)
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", value)
      if (tolower(name) == tolower(wanted)) {
        print value
        exit
      }
    }
  ' "$file"
}

latest_review_for_sha() {
  local short_sha="$1"
  ls -t "$ROOT/.agents/runs/${TASK_ID}-qa-review-${short_sha}"*.md 2>/dev/null | head -1
}

find_pipeline_id() {
  local sha="$1" out="$RUN_ROOT/pipelines-$sha.json"
  agentmarshal/scripts/gitflic-ci.sh sha "$sha" > "$out"
  jq -r 'sort_by(.localId) | reverse | .[0].localId // empty' "$out"
}

wait_pipeline_for_sha() {
  local sha="$1" label="$2" attempt pipeline_id
  for attempt in 1 2 3; do
    section "$label pipeline lookup attempt $attempt"
    pipeline_id="$(find_pipeline_id "$sha" || true)"
    if [[ "$pipeline_id" =~ ^[0-9]+$ ]]; then
      PIPELINE_ID="$pipeline_id"
      run agentmarshal/scripts/gitflic-ci.sh wait "$pipeline_id" "$PIPELINE_TIMEOUT" "$PIPELINE_POLL"
      return 0
    fi
    sleep "$PIPELINE_POLL"
  done
  fail "$label pipeline" "pipeline for SHA $sha was not found"
}

run_review_loop() {
  local sha="$1" label="$2" loop short_sha verdict reviewed
  short_sha="${sha:0:7}"
  for ((loop = 1; loop <= MAX_REVIEW_LOOPS; loop++)); do
    section "$label review loop $loop/$MAX_REVIEW_LOOPS"
    run agentmarshal/scripts/review-readonly.sh \
      --task "$TASK_ID" \
      --sha "$sha" \
      --base "$BASE_REF" \
      --vendor "$REVIEW_VENDOR" \
      --model "$REVIEW_MODEL"
    REVIEW_FILE="$(latest_review_for_sha "$short_sha")"
    [[ -n "${REVIEW_FILE:-}" && -f "$REVIEW_FILE" ]] \
      || fail "$label review" "review artifact for $short_sha was not found"
    reviewed="$(review_field "$REVIEW_FILE" Reviewed-Commit | tr -d ' ')"
    verdict="$(review_field "$REVIEW_FILE" Verdict | tr 'A-Z' 'a-z' | tr -d ' *`')"
    [[ "$reviewed" == "$sha" ]] \
      || fail "$label review" "reviewed commit '$reviewed' does not match '$sha'"
    case "$verdict" in
      approved|approve|ok|lgtm)
        note "review approved: $REVIEW_FILE"
        return 0
        ;;
      changes_required|blocked|rejected)
        fail "$label review" "review returned $verdict: $REVIEW_FILE"
        ;;
      *)
        fail "$label review" "unknown review verdict '$verdict': $REVIEW_FILE"
        ;;
    esac
  done
  fail "$label review" "review loop limit exceeded"
}

load_state

section "00 preflight"
if should_run 00; then
  git diff --quiet || fail "00 preflight" "working tree has unstaged changes"
  git diff --cached --quiet || fail "00 preflight" "index has staged changes"
  current_branch="$(git branch --show-current)"
  [[ "$current_branch" == "$BRANCH" ]] \
    || fail "00 preflight" "expected branch $BRANCH, got $current_branch"
  run bash agentmarshal/scripts/validate.sh
  IMPLEMENTATION_SHA="$(git rev-parse HEAD)"
  write_state
else
  note "skipped by RUNBOOK_FROM=$RUNBOOK_FROM"
  [[ -n "${IMPLEMENTATION_SHA:-}" ]] || IMPLEMENTATION_SHA="$(git rev-parse HEAD)"
fi
note "Task: $TASK_ID"
note "Branch: $BRANCH"
note "Implementation-SHA: $IMPLEMENTATION_SHA"

section "10 push and MR"
if should_run 10; then
  run git push -u origin "$BRANCH"
  mr_output="$RUN_ROOT/mr-create.txt"
  if [[ -z "${MR_ID:-}" ]]; then
    infrastructure/scripts/mr.sh create --from "$BRANCH" "$TASK_ID: protocol runbook implementation" "$TARGET_BRANCH" > "$mr_output" 2>&1
    cat "$mr_output" | tee -a "$LOG_FILE" >&2
    MR_ID="$(grep -oE 'MR #[0-9]+' "$mr_output" | grep -oE '[0-9]+' | tail -1)"
  fi
  [[ "$MR_ID" =~ ^[0-9]+$ ]] || fail "10 push and MR" "could not parse MR id from $mr_output"
  write_state
else
  note "skipped by RUNBOOK_FROM=$RUNBOOK_FROM"
fi
[[ "${MR_ID:-}" =~ ^[0-9]+$ ]] || fail "10 push and MR" "MR_ID is required for later sections"
note "MR: $MR_ID"

section "20 pipeline"
if should_run 20; then
  wait_pipeline_for_sha "$IMPLEMENTATION_SHA" "implementation"
  write_state
else
  note "skipped by RUNBOOK_FROM=$RUNBOOK_FROM"
fi

section "30 review loop"
if should_run 30; then
  run_review_loop "$IMPLEMENTATION_SHA" "implementation"
  IMPLEMENTATION_REVIEW_FILE="$REVIEW_FILE"
  write_state
else
  note "skipped by RUNBOOK_FROM=$RUNBOOK_FROM"
fi
IMPLEMENTATION_REVIEW_FILE="${IMPLEMENTATION_REVIEW_FILE:-${REVIEW_FILE:-}}"
[[ -n "$IMPLEMENTATION_REVIEW_FILE" ]] || fail "30 review loop" "IMPLEMENTATION_REVIEW_FILE is required"

section "40 merge policy"
if should_run 40; then
  run env AGENTMARSHAL_PIPELINE_OK_SHA="$IMPLEMENTATION_SHA" \
    AGENTMARSHAL_REVIEW_FILE="${IMPLEMENTATION_REVIEW_FILE#$ROOT/}" \
    agentmarshal/scripts/merge-policy.sh \
      --branch "$BRANCH" \
      --head "$IMPLEMENTATION_SHA" \
      --base "$BASE_REF" \
      --task "$TASK_ID" \
      --review-file "${IMPLEMENTATION_REVIEW_FILE#$ROOT/}"
else
  note "skipped by RUNBOOK_FROM=$RUNBOOK_FROM"
fi

section "50 merge"
if should_run 50; then
  run env AGENTMARSHAL_PIPELINE_OK_SHA="$IMPLEMENTATION_SHA" \
    AGENTMARSHAL_REVIEW_FILE="${IMPLEMENTATION_REVIEW_FILE#$ROOT/}" \
    infrastructure/scripts/mr.sh merge "$MR_ID" "$TASK_ID"
else
  note "skipped by RUNBOOK_FROM=$RUNBOOK_FROM"
fi

section "60 completion transaction"
if should_run 60; then
  run git fetch origin
  run git switch "$TARGET_BRANCH"
  run git merge --ff-only "origin/$TARGET_BRANCH"
  COMPLETION_BRANCH="completion/${TASK_ID,,}-protocol-runbook"
  if git rev-parse --verify --quiet "$COMPLETION_BRANCH" >/dev/null; then
    run git switch "$COMPLETION_BRANCH"
  else
    run git switch -c "$COMPLETION_BRANCH"
  fi
  run agentmarshal/scripts/task-lifecycle.sh complete \
    --task "$TASK_ID" \
    --review-task "$TASK_ID" \
    --review-file "${IMPLEMENTATION_REVIEW_FILE#$ROOT/}" \
    --reviewed-commit "$IMPLEMENTATION_SHA" \
    --target-ref "$TARGET_BRANCH"
  run bash agentmarshal/scripts/validate.sh
  run git add .agents/tasks/open ".agents/tasks/done" ".agents/reviews"
  run git commit -m "chore(agentmarshal): complete $TASK_ID protocol runbook"
  COMPLETION_SHA="$(git rev-parse HEAD)"
  write_state
else
  note "skipped by RUNBOOK_FROM=$RUNBOOK_FROM"
fi
note "Completion-SHA: $COMPLETION_SHA"

section "70 completion push and MR"
if should_run 70; then
  run git push -u origin "$COMPLETION_BRANCH"
  completion_mr_output="$RUN_ROOT/completion-mr-create.txt"
  if [[ -z "${COMPLETION_MR_ID:-}" ]]; then
    infrastructure/scripts/mr.sh create --from "$COMPLETION_BRANCH" "$TASK_ID: completion journal" "$TARGET_BRANCH" > "$completion_mr_output" 2>&1
    cat "$completion_mr_output" | tee -a "$LOG_FILE" >&2
    COMPLETION_MR_ID="$(grep -oE 'MR #[0-9]+' "$completion_mr_output" | grep -oE '[0-9]+' | tail -1)"
  fi
  [[ "$COMPLETION_MR_ID" =~ ^[0-9]+$ ]] \
    || fail "70 completion push and MR" "could not parse completion MR id from $completion_mr_output"
  write_state
else
  note "skipped by RUNBOOK_FROM=$RUNBOOK_FROM"
fi
[[ "${COMPLETION_MR_ID:-}" =~ ^[0-9]+$ ]] \
  || fail "70 completion push and MR" "COMPLETION_MR_ID is required for later sections"

section "80 completion pipeline"
if should_run 80; then
  wait_pipeline_for_sha "$COMPLETION_SHA" "completion"
  write_state
else
  note "skipped by RUNBOOK_FROM=$RUNBOOK_FROM"
fi

section "90 completion review"
if should_run 90; then
  run_review_loop "$COMPLETION_SHA" "completion"
  COMPLETION_REVIEW_FILE="$REVIEW_FILE"
  write_state
else
  note "skipped by RUNBOOK_FROM=$RUNBOOK_FROM"
fi
[[ -n "${COMPLETION_REVIEW_FILE:-}" ]] || fail "90 completion review" "COMPLETION_REVIEW_FILE is required"

section "95 completion merge"
if should_run 95; then
  run env AGENTMARSHAL_PIPELINE_OK_SHA="$COMPLETION_SHA" \
    AGENTMARSHAL_REVIEW_FILE="${COMPLETION_REVIEW_FILE#$ROOT/}" \
    infrastructure/scripts/mr.sh merge "$COMPLETION_MR_ID" "$TASK_ID"
else
  note "skipped by RUNBOOK_FROM=$RUNBOOK_FROM"
fi

section "99 summary"
note "AGENTMARSHAL_RUNBOOK_SUCCESS"
note "Task: $TASK_ID"
note "Implementation-SHA: $IMPLEMENTATION_SHA"
note "Implementation-MR: $MR_ID"
note "Implementation-Review: ${REVIEW_FILE#$ROOT/}"
note "Completion-SHA: $COMPLETION_SHA"
note "Completion-MR: $COMPLETION_MR_ID"
note "Completion-Review: ${COMPLETION_REVIEW_FILE#$ROOT/}"
note "Log: $LOG_FILE"
